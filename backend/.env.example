SAFERIDE_APP_NAME=SafeRide API
SAFERIDE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Pricing
SAFERIDE_FARE_PER_KM_XAF=350
SAFERIDE_BASE_FARE_XAF=500
SAFERIDE_COMMISSION_RATE=0.08
SAFERIDE_PREMIUM_XAF=5000

# Admin (change me in production)
SAFERIDE_ADMIN_TOKEN=saferide-admin-dev

# Chariow checkout (https://chariow.com)
# Replace with the real product link from your Chariow dashboard.
SAFERIDE_CHARIOW_CHECKOUT_URL=https://chariow.com/saferide/premium-driver

# Nokia Network-as-Code (https://networkascode.nokia.io)
# When SAFERIDE_USE_REAL_NAC=true, the backend forwards calls to the real CAMARA
# endpoints via Nokia NaC. Otherwise the local mock service is used.
SAFERIDE_USE_REAL_NAC=false
SAFERIDE_NOKIA_NAC_BASE_URL=https://network-as-code.p-eu.rapidapi.com
SAFERIDE_NOKIA_NAC_API_KEY=

# OpenRouter (https://openrouter.ai) — Agent IA (LLM gratuit)
# Free models verifies: openai/gpt-oss-20b:free (defaut, JSON propre),
#   openai/gpt-oss-120b:free, z-ai/glm-4.5-air:free, minimax/minimax-m2.5:free
# Liste a jour : https://openrouter.ai/models?max_price=0
# Si la cle est vide, le backend retombe sur des messages templatises bilingues.
SAFERIDE_OPENROUTER_API_KEY=
SAFERIDE_OPENROUTER_MODEL=openai/gpt-oss-20b:free
SAFERIDE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SAFERIDE_OPENROUTER_REFERER=https://saferide.app
SAFERIDE_OPENROUTER_APP_NAME=SafeRide
SAFERIDE_OPENROUTER_TIMEOUT=8
